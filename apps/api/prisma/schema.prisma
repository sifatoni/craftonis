generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── TENANTS ────────────────────────────────────────────────
model Tenant {
  id            String   @id @default(uuid())
  name          String
  domain        String?  @unique
  plan          Plan     @default(STARTER)
  tokenBalance  Int      @default(0)
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  departments   Department[]
  jobs          Job[]
  candidates    Candidate[]
  meetings      Meeting[]
  leads         Lead[]
  tokenWallet   TokenWallet?
  subscriptions Subscription[]
  questions     Question[]
  onboardingPlans OnboardingPlan[]

  @@map("tenants")
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

// ── USERS ──────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  email        String
  role         Role     @default(VIEWER)
  passwordHash String
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  HR_MANAGER
  INTERVIEWER
  DEPT_HEAD
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

// ── DEPARTMENTS ────────────────────────────────────────────
model Department {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  managerId   String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employees Employee[]
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  jobs      Job[]
  meetings  Meeting[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("departments")
}

// ── JOBS ───────────────────────────────────────────────────
model Job {
  id           String    @id @default(uuid())
  tenantId     String
  departmentId String?
  title        String
  description  String?
  requirements String?
  salaryMin    Int?
  salaryMax    Int?
  status       JobStatus @default(OPEN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  candidates   Candidate[]
  interviews   Interview[]

  @@map("jobs")
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
  DRAFT
}

// ── CANDIDATES ─────────────────────────────────────────────
model Candidate {
  id          String          @id @default(uuid())
  tenantId    String
  jobId       String?
  name        String
  email       String
  phone       String?
  cvUrl       String?
  stage       CandidateStage  @default(APPLIED)
  totalScore  Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  job         Job?            @relation(fields: [jobId], references: [id])
  cvScore     CvScore?
  interviews  Interview[]
  onboardingPlans OnboardingPlan[]

  @@map("candidates")
}

enum CandidateStage {
  APPLIED
  CV_REVIEWED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

// ── CV SCORES ──────────────────────────────────────────────
model CvScore {
  id           String    @id @default(uuid())
  candidateId  String    @unique
  skillMatch   Float     @default(0)
  stability    Float     @default(0)
  education    Float     @default(0)
  totalScore   Float     @default(0)
  parsedData   Json?
  createdAt    DateTime  @default(now())

  candidate    Candidate @relation(fields: [candidateId], references: [id])

  @@map("cv_scores")
}

// ── INTERVIEWS ─────────────────────────────────────────────
model Interview {
  id            String          @id @default(uuid())
  candidateId   String
  interviewerId String
  jobId         String?
  types         Json            @default("[]")
  scheduledAt   DateTime?
  status        InterviewStatus @default(SCHEDULED)
  ratings       Json?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  candidate     Candidate       @relation(fields: [candidateId], references: [id])
  job           Job?            @relation(fields: [jobId], references: [id])
  room          InterviewRoom?

  @@map("interviews")
}

enum InterviewType {
  GENERAL
  TECHNICAL
  BEHAVIORAL
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── INTERVIEW ROOM ─────────────────────────────────────────
model InterviewRoom {
  id            String    @id @default(uuid())
  interviewId   String    @unique
  roomCode      String    @unique @default(uuid())
  status        String    @default("WAITING") // WAITING, ACTIVE, ENDED
  transcript    Json?     // array of { speaker, text, timestampMs }
  aiScore       Json?     // { communication, technical, behavioral, overall, summary }
  codeContent   String?   @default("")
  codeLanguage  String?   @default("javascript")
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interview_rooms")
}

// ── MEETINGS ───────────────────────────────────────────────
model Meeting {
  id          String        @id @default(uuid())
  tenantId    String
  hostId      String
  roomCode    String        @unique @default(uuid())
  title       String?
  scheduledFor  DateTime?
  meetingType   String?
  clientName    String?
  departmentId  String?
  participants  Json?
  startedAt   DateTime?
  endedAt     DateTime?
  recordingUrl String?
  status      MeetingStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  department  Department?   @relation(fields: [departmentId], references: [id])
  transcripts Transcript[]
  minutes     MeetingMinutes?

  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

// ── TRANSCRIPTS ────────────────────────────────────────────
model Transcript {
  id          String   @id @default(uuid())
  meetingId   String
  speaker     String?
  text        String
  timestampMs Int      @default(0)
  flagged     Boolean  @default(false)
  createdAt   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id])

  @@map("transcripts")
}

// ── MEETING MINUTES ────────────────────────────────────────
model MeetingMinutes {
  id          String   @id @default(uuid())
  meetingId   String   @unique
  summary     String?
  decisions   Json?
  actionItems Json?
  keyPoints   Json?
  nextSteps   String?
  sentiment   String?
  approved    Boolean  @default(false)
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id])

  @@map("meeting_minutes")
}

// ── LEADS ──────────────────────────────────────────────────
model Lead {
  id           String   @id @default(uuid())
  tenantId     String
  name         String?
  designation  String?
  organization String?
  email        String?
  emailType    String?
  phone        String?
  linkedinUrl  String?
  instagramUrl String?
  facebookUrl  String?
  profileUrl   String?
  location     String?
  area         String?
  industry     String?
  snippet      String?
  platform     String?
  source       String?
  contactScore Int      @default(0)
  valueBand    String   @default("Low")
  revealed     Boolean  @default(false)
  crmStage     String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  @@map("leads")
}

// ── ONBOARDING ─────────────────────────────────────────────
model OnboardingPlan {
  id            String              @id @default(uuid())
  tenantId      String
  candidateId   String
  jobId         String?
  title         String              @default("Onboarding Plan")
  durationDays  Int                 @default(30)
  startDate     DateTime?
  status        String              @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  aiGenerated   Boolean             @default(false)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  candidate     Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  weeks         OnboardingWeek[]
  documents     OnboardingDocument[]

  @@map("onboarding_plans")
}

model OnboardingWeek {
  id          String            @id @default(uuid())
  planId      String
  weekNumber  Int
  title       String
  description String?
  tasks       OnboardingTask[]
  plan        OnboardingPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("onboarding_weeks")
}

model OnboardingTask {
  id          String         @id @default(uuid())
  weekId      String
  title       String
  description String?
  category    String?        // DOCUMENTATION, TRAINING, MEETING, SETUP, GOAL
  dueDay      Int?           // day number within the plan (1-90 etc)
  completed   Boolean        @default(false)
  completedAt DateTime?
  assignee    String?        // person responsible
  week        OnboardingWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

model OnboardingDocument {
  id         String         @id @default(uuid())
  planId     String
  fileName   String
  fileType   String
  fileSize   Int
  fileUrl    String?        // R2/S3 URL (optional for now, store base64 or path)
  uploadedAt DateTime       @default(now())
  plan       OnboardingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("onboarding_documents")
}

enum LeadStage {
  NEW
  CONTACTED
  RESPONDED
  QUALIFIED
}

// ── TOKEN LEDGER ───────────────────────────────────────────
model TokenWallet {
  id        String        @id @default(uuid())
  tenantId  String        @unique
  balance   Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  ledger    TokenLedger[]
  @@map("token_wallets")
}

model TokenLedger {
  id          String      @id @default(uuid())
  walletId    String
  type        String
  amount      Int
  description String?
  leadId      String?
  createdAt   DateTime    @default(now())
  wallet      TokenWallet @relation(fields: [walletId], references: [id])
  @@map("token_ledger")
}



// ── EMPLOYEES (HRM) ────────────────────────────────────────
model Employee {
  id                 String         @id @default(cuid())
  tenantId           String
  userId             String?        @unique
  firstName          String
  lastName           String
  email              String?
  phone              String?
  gender             Gender?
  dateOfBirth        DateTime?
  nationalId         String?
  address            String?
  departmentId       String?
  employmentType     EmploymentType @default(FULL_TIME)
  designation        String?
  jobRole            String?
  reportingToId      String?
  joinDate           DateTime?
  status             EmployeeStatus @default(ACTIVE)
  basicSalary        Float?
  houseAllowance     Float?
  transportAllowance Float?
  medicalAllowance   Float?
  otherAllowance     Float?
  emergencyContact   String?
  emergencyPhone     String?
  emergencyRelation  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  department  Department? @relation(fields: [departmentId], references: [id])
  reportingTo Employee?   @relation("ReportsTo", fields: [reportingToId], references: [id])
  reportees   Employee[]  @relation("ReportsTo")

  attendanceLogs AttendanceLog[]
  leaveRequests LeaveRequest[]
  payrolls     Payroll[]

  @@index([tenantId])
  @@map("employees")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

// ── ATTENDANCE ─────────────────────────────────────────────
model AttendanceLog {
  id            String           @id @default(cuid())
  tenantId      String
  employeeId    String
  date          DateTime
  checkinTime   DateTime?
  checkoutTime  DateTime?
  hoursWorked   Float?
  status        AttendanceStatus @default(PRESENT)
  notes         String?
  lat           Float?
  lon           Float?
  locationName  String?
  timezone      String?
  createdAt     DateTime         @default(now())

  employee      Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([tenantId])
  @@map("attendance_logs")
}

enum AttendanceStatus { 
  PRESENT 
  LATE 
  ABSENT 
  HALF_DAY 
  LEAVE 
  HOLIDAY 
  ON_LEAVE
}

// ── HOLIDAYS ───────────────────────────────────────────────
model Holiday {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  date      DateTime
  type      HolidayType @default(PUBLIC)
  createdAt DateTime    @default(now())

  @@index([tenantId])
  @@map("holidays")
}

enum HolidayType {
  PUBLIC
  COMPANY
}

// ── LEAVE REQUESTS ─────────────────────────────────────────
model LeaveRequest {
  id              String        @id @default(cuid())
  tenantId        String
  employeeId      String
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  reason          String?
  status          LeaveStatus   @default(PENDING)
  approverId      String?
  approverComment String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee        Employee      @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("leave_requests")
}

enum LeaveType { 
  ANNUAL 
  SICK 
  CASUAL 
  MATERNITY 
  PATERNITY 
  UNPAID 
}

enum LeaveStatus { 
  PENDING 
  APPROVED 
  REJECTED 
  CANCELLED 
}

// ── PAYROLL ────────────────────────────────────────────────
model Payroll {
  id          String   @id @default(uuid())
  employeeId  String
  month       DateTime @db.Date
  basic       Float    @default(0)
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  netPay      Float    @default(0)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month])
  @@map("payroll")
}

// ── SUBSCRIPTIONS ──────────────────────────────────────────
model Subscription {
  id            String             @id @default(uuid())
  tenantId      String             @unique
  plan          Plan               @default(STARTER)
  status        SubscriptionStatus @default(ACTIVE)
  billingCycle  BillingCycle       @default(MONTHLY)
  nextBillingAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

// ── QUESTION BANK ──────────────────────────────────────────
model Question {
  id        String        @id @default(uuid())
  tenantId  String
  type      InterviewType
  text      String
  category  String?
  isCustom  Boolean       @default(false)
  order     Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])

  @@map("questions")
}

// ── NEW ENUMS ──────────────────────────────────────────────
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}
